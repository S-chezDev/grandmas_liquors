# Configuración de Backend para Producción (AWS RDS + Elastic Beanstalk)
# Copiar este archivo a .env.production y completar con los valores reales

# Configuración de Base de Datos (PostgreSQL RDS)
DB_HOST=TU_RDS_ENDPOINT.us-east-2.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TU_DB_PASSWORD_SEGURO
DB_DATABASE=postgres
DB_SSL=true

# Servidor
PORT=3002
NODE_ENV=production
PUBLIC_BASE_URL=https://TU_EB_ENV.us-east-2.elasticbeanstalk.com

# CORS (Configurar con dominio de CloudFront y dominio personalizado)
# Después de crear CloudFront, actualizar con: https://TU_DISTRIBUTION.cloudfront.net
CORS_CLOUDFRONT_URL=https://TU_DISTRIBUTION.cloudfront.net
# Si tienes dominio personalizado, agregarlo aquí
CORS_CUSTOM_DOMAIN=https://www.tu-dominio.com
# Orígenes permitidos (separados por comas)
CORS_ORIGINS=https://TU_DISTRIBUTION.cloudfront.net,https://www.tu-dominio.com

# Uploads (Elastic Beanstalk usa /var/app/current/uploads)
UPLOADS_ROOT=/var/app/current/uploads

# Authentication
# Generar JWT_SECRET seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=TU_JWT_SECRET_MIN_32_CARACTERES
JWT_ISSUER=grandmas-liquors-api
JWT_AUDIENCE=grandmas-liquors-web
AUTH_COOKIE_NAME=gl_session
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=.tu-dominio.com
JWT_CLIENTE_TTL_MS=3600000
JWT_STAFF_TTL_MS=10800000
JWT_LONG_SESSION_TTL_MS=604800000
SESSION_IDLE_TIMEOUT_MS=1800000

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Email (configurar con servicio real de email para producción)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu-email@gmail.com
MAIL_PASSWORD=TU_APP_PASSWORD
MAIL_FROM="Grandma's Liquors <tu-email@gmail.com>"

# System Admin
SYSTEM_ADMIN_EMAIL=tu-email@gmail.com
