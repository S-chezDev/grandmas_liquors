# Configuración de Frontend para Producción (AWS S3 + CloudFront)
# Copiar este archivo a .env.production y completar con los valores reales

# URL de la API en Elastic Beanstalk (se obtiene después de desplegar EB)
# Formato: https://tu-env-name.region.elasticbeanstalk.com
VITE_API_BASE_URL=https://TU_EB_ENV.us-east-2.elasticbeanstalk.com
VITE_API_PROXY_TARGET=https://TU_EB_ENV.us-east-2.elasticbeanstalk.com
